# Copy to .env and adjust. Loaded by modules/config.js (dotenv).

# --- HTTP / HTTPS server ---
PORT=3000
NODE_ENV=development
# BIND_HOST=0.0.0.0

# Public URL (no trailing slash). Use behind a domain / reverse proxy, e.g. https://monitor.example.com
# PUBLIC_URL=https://monitor.example.com

# Native TLS (see certs/README.md): either privkey.pem + fullchain.pem, OR private.key + certificate.cer in ./certs/
# Or set paths explicitly (PEM or DER .cer; .key PEM or DER PKCS#8/PKCS#1):
# SSL_KEY_PATH=certs/private.key
# SSL_CERT_PATH=certs/certificate.cer
# SSL_CA_PATH=certs/chain.cer
# SSL_KEY_PATH=certs/privkey.pem
# SSL_CERT_PATH=certs/fullchain.pem
# SSL_CA_PATH=certs/chain.pem

# Behind nginx/Caddy: terminate TLS at the proxy and set TRUST_PROXY so Express sees HTTPS and real client IP.
# TRUST_PROXY=1

# Secure cookies: auto-enabled for HTTPS or production. Override: COOKIE_SECURE=0 or COOKIE_SECURE=1
# COOKIE_SECURE=1

# --- Default API targets (fallback when no connection is stored in the UI) ---
PROXMOX_HOST=10.200.0.1
PROXMOX_PORT=8006

TRUENAS_HOST=10.200.0.2
TRUENAS_PORT=443

# --- CORS (Express cors origin; default * allows any origin) ---
CORS_ORIGIN=*

# --- In-memory cache TTL (seconds); used for API response caching ---
CACHE_TTL=30

# --- Default UI language (server-side / i18n bootstrap) ---
DEFAULT_LANGUAGE=ru

# --- Application logs (utils.js file logger; default: ./data/logs) ---
# LOG_DIR=/var/log/proxmox-monitor
LOG_MAX_BYTES=5242880
LOG_BACKUPS=5

# --- Speedtest CLI (optional path to speedtest or Ookla binary) ---
# SPEEDTEST_CLI=/usr/bin/speedtest
# SPEEDTEST_PATH=/usr/local/bin/speedtest

# --- Optional: Proxmox host metrics agent (extras/proxmox-host-metrics-agent.js) ---
# HOST_METRICS_AGENT_HOST=0.0.0.0
# HOST_METRICS_AGENT_PORT=9105
# HOST_METRICS_AGENT_BASE_PATH=/host-metrics
# HOST_METRICS_SENSORS_BIN=sensors
# HOST_METRICS_ETHTOOL_BIN=ethtool
# HOST_METRICS_COMMAND_TIMEOUT_MS=3000
