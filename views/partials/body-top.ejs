<body>
    <div class="backend-offline-banner d-none" id="backendOfflineBanner" role="status" aria-live="polite">
        <div class="backend-offline-banner__text">SERVER OFFLINE</div>
    </div>
    <div class="toast-container" id="toastContainer"></div>

    <!-- Settings unlock (password) -->
    <div class="modal fade" id="settingsUnlockModal" tabindex="-1" aria-labelledby="settingsUnlockModalTitle" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="settingsUnlockModalTitle"><i class="bi bi-shield-lock me-2"></i><span id="settingsUnlockModalTitleText">Enter settings password</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="settingsUnlockModalCloseBtn"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="settingsUnlockPassword" id="settingsUnlockPasswordLabel">Password</label>
                        <input type="password" class="form-control form-control-lg" id="settingsUnlockPassword" placeholder="" autocomplete="current-password">
                        <div class="invalid-feedback" id="settingsUnlockError"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" id="settingsUnlockCancelBtn"><span id="settingsUnlockCancelText">Cancel</span></button>
                    <button type="button" class="btn btn-primary" id="settingsUnlockSubmitBtn"><i class="bi bi-unlock me-1"></i><span id="settingsUnlockSubmitText">Unlock</span></button>
                </div>
            </div>
        </div>
    </div>

    <!-- In-place update (git checkout + npm) — requires UPDATE_APPLY_ENABLED and password or token -->
    <div class="modal fade" id="appUpdateApplyModal" tabindex="-1" aria-labelledby="appUpdateApplyModalTitle" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="appUpdateApplyModalTitle"><i class="bi bi-cloud-download me-2"></i><span id="appUpdateApplyModalTitleText">Update application</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="appUpdateApplyModalCloseBtn"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3" id="appUpdateApplyModalHint"></p>
                    <div class="mb-3" id="appUpdateApplyPasswordWrap" style="display: none;">
                        <label class="form-label fw-bold" for="appUpdateApplyPassword" id="appUpdateApplyPasswordLabel">Settings password</label>
                        <input type="password" class="form-control" id="appUpdateApplyPassword" autocomplete="current-password">
                    </div>
                    <div class="mb-3" id="appUpdateApplyTokenWrap" style="display: none;">
                        <label class="form-label fw-bold" for="appUpdateApplyToken" id="appUpdateApplyTokenLabel">Update token</label>
                        <input type="password" class="form-control" id="appUpdateApplyToken" autocomplete="off">
                    </div>
                    <div class="invalid-feedback d-block" id="appUpdateApplyError"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="appUpdateApplyCancelBtn"><span id="appUpdateApplyCancelText">Cancel</span></button>
                    <button type="button" class="btn btn-warning" id="appUpdateApplySubmitBtn"><i class="bi bi-download me-1"></i><span id="appUpdateApplySubmitText">Update</span></button>
                </div>
            </div>
        </div>
    </div>

<%- include('./setup-wizard') %>

    <!-- Telegram rule message template -->
    <div class="modal fade" id="telegramRuleMessageModal" tabindex="-1" aria-labelledby="telegramRuleMessageModalTitle" aria-hidden="true" data-bs-backdrop="true" data-bs-keyboard="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="telegramRuleMessageModalTitle"><i class="bi bi-chat-text me-2"></i><span id="telegramRuleMessageModalTitleText"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-2" id="telegramRuleMessageModalTypeLine"></p>
                    <p class="small text-muted mb-3" id="telegramRuleMessageModalEmptyHint"></p>
                    <label class="form-label fw-bold" for="telegramRuleMessageModalTextarea" id="telegramRuleMessageModalTextareaLabel"></label>
                    <textarea class="form-control font-monospace" id="telegramRuleMessageModalTextarea" rows="8" maxlength="4096" placeholder=""></textarea>
                    <div class="mt-3">
                        <div class="fw-semibold small mb-2" id="telegramRuleMessageModalVarsTitle"></div>
                        <ul class="small mb-0 ps-3" id="telegramRuleMessageModalVarsList"></ul>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="telegramRuleMessageModalCancelBtn"><span id="telegramRuleMessageModalCancelText"></span></button>
                    <button type="button" class="btn btn-primary" id="telegramRuleMessageModalSaveBtn"><i class="bi bi-check-lg me-1"></i><span id="telegramRuleMessageModalSaveText"></span></button>
                </div>
            </div>
        </div>
    </div>

    <!-- Host metrics agent install via SSH -->
    <div class="modal fade" id="hostMetricsAgentInstallModal" tabindex="-1" aria-labelledby="hostMetricsAgentInstallModalTitle" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false" data-agent-mode="install">
        <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="hostMetricsAgentInstallModalTitle"><i class="bi bi-cloud-download me-2" id="hostMetricsAgentInstallModalTitleIcon" aria-hidden="true"></i><span id="hostMetricsAgentInstallTitleText">Install host metrics agent</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3" id="hostMetricsAgentInstallIntro"></p>
                    <div id="hostMetricsAgentInstallStep1">
                        <div class="row g-2 mb-2">
                            <div class="col-md-8">
                                <label class="form-label fw-bold" for="hostMetricsAgentSshHost" id="hostMetricsAgentInstallSshHostLabel">SSH host</label>
                                <input type="text" class="form-control" id="hostMetricsAgentSshHost" placeholder="10.0.0.5 or pve" autocomplete="off">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold" for="hostMetricsAgentSshPort" id="hostMetricsAgentInstallSshPortLabel">Port</label>
                                <input type="number" class="form-control" id="hostMetricsAgentSshPort" value="22" min="1" max="65535">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold" for="hostMetricsAgentSshUser" id="hostMetricsAgentInstallSshUserLabel">User</label>
                                <input type="text" class="form-control" id="hostMetricsAgentSshUser" value="root" autocomplete="username">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold" for="hostMetricsAgentSshPassword" id="hostMetricsAgentInstallSshPasswordLabel">Password</label>
                                <input type="password" class="form-control" id="hostMetricsAgentSshPassword" autocomplete="new-password">
                            </div>
                        </div>
                        <button type="button" class="btn btn-primary" id="hostMetricsAgentInstallNextBtn"><span id="hostMetricsAgentInstallNextBtnText">Next: command plan</span></button>
                    </div>
                    <div id="hostMetricsAgentInstallStep2" class="d-none">
                        <label class="form-label fw-bold" for="hostMetricsAgentInstallPlanText" id="hostMetricsAgentInstallPlanLabel">Commands and actions</label>
                        <textarea id="hostMetricsAgentInstallPlanText" class="form-control font-monospace small" rows="16" readonly></textarea>
                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" id="hostMetricsAgentInstallConfirm">
                            <label class="form-check-label" for="hostMetricsAgentInstallConfirm" id="hostMetricsAgentInstallConfirmLabel">I confirm that I want to run these commands on the remote host</label>
                        </div>
                        <div id="hostMetricsAgentInstallResultWrap" class="mt-3 d-none">
                            <label class="form-label fw-bold" id="hostMetricsAgentInstallResultLabel">Output</label>
                            <pre id="hostMetricsAgentInstallResult" class="small bg-light border rounded p-2 mb-0" style="max-height: 200px; overflow: auto;"></pre>
                        </div>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button type="button" class="btn btn-outline-secondary" id="hostMetricsAgentInstallBackBtn"><span id="hostMetricsAgentInstallBackBtnText">Back</span></button>
                            <button type="button" class="btn btn-danger" id="hostMetricsAgentInstallRunBtn" disabled><span id="hostMetricsAgentInstallRunBtnText">Install / update</span></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="hostNodeAllMetricsModal" tabindex="-1" aria-labelledby="hostNodeAllMetricsModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="hostNodeAllMetricsModalTitle"><i class="bi bi-graph-up-arrow me-2" id="hostNodeAllMetricsModalTitleIcon" aria-hidden="true"></i><span id="hostNodeAllMetricsModalTitleText">Node metrics</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3 small" id="hostNodeAllMetricsModalSubtitle"></div>
                    <div id="hostNodeAllMetricsGlobalError" class="alert alert-danger py-2 d-none" role="alert"></div>

                    <h6 class="fw-semibold mb-1"><i class="bi bi-thermometer-half me-1"></i><span id="hostNodeChartSectionLabelTemp"></span></h6>
                    <div id="hostNodeChartTempEmpty" class="alert alert-light border small py-2 mb-3 d-none" role="status"></div>
                    <div id="hostNodeChartTempWrap" class="position-relative mb-4" style="height: 200px;"><canvas id="hostNodeChartCanvasTemp" aria-label="CPU temperature chart"></canvas></div>

                    <h6 class="fw-semibold mb-1"><i class="bi bi-cpu me-1"></i><span id="hostNodeChartSectionLabelCpu"></span></h6>
                    <div id="hostNodeChartCpuEmpty" class="alert alert-light border small py-2 mb-3 d-none" role="status"></div>
                    <div id="hostNodeChartCpuWrap" class="position-relative mb-4" style="height: 200px;"><canvas id="hostNodeChartCanvasCpu" aria-label="CPU usage chart"></canvas></div>

                    <h6 class="fw-semibold mb-1"><i class="bi bi-memory me-1"></i><span id="hostNodeChartSectionLabelMem"></span></h6>
                    <div id="hostNodeChartMemEmpty" class="alert alert-light border small py-2 mb-3 d-none" role="status"></div>
                    <div id="hostNodeChartMemWrap" class="position-relative" style="height: 200px;"><canvas id="hostNodeChartCanvasMem" aria-label="RAM usage chart"></canvas></div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="clusterAggregateMetricsModal" tabindex="-1" aria-labelledby="clusterAggregateMetricsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="clusterAggregateMetricsModalLabel"><i class="bi bi-graph-up-arrow me-2" id="clusterAggregateMetricsModalTitleIcon" aria-hidden="true"></i><span id="clusterAggregateMetricsModalTitleText">Cluster metrics</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3 small" id="clusterAggregateMetricsModalSubtitle"></div>
                    <div id="clusterAggregateMetricsGlobalError" class="alert alert-danger py-2 d-none" role="alert"></div>

                    <h6 class="fw-semibold mb-1"><i class="bi bi-cpu me-1"></i><span id="clusterAggChartSectionLabelCpu"></span></h6>
                    <div id="clusterAggChartCpuEmpty" class="alert alert-light border small py-2 mb-3 d-none" role="status"></div>
                    <div id="clusterAggChartCpuWrap" class="position-relative mb-4" style="height: 200px;"><canvas id="clusterAggChartCanvasCpu" aria-label="Cluster CPU usage chart"></canvas></div>

                    <h6 class="fw-semibold mb-1"><i class="bi bi-memory me-1"></i><span id="clusterAggChartSectionLabelMem"></span></h6>
                    <div id="clusterAggChartMemEmpty" class="alert alert-light border small py-2 mb-3 d-none" role="status"></div>
                    <div id="clusterAggChartMemWrap" class="position-relative" style="height: 200px;"><canvas id="clusterAggChartCanvasMem" aria-label="Cluster RAM usage chart"></canvas></div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="upsAllMetricsModal" tabindex="-1" aria-labelledby="upsAllMetricsModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="upsAllMetricsModalTitle"><i class="bi bi-lightning-charge me-2" id="upsAllMetricsModalTitleIcon" aria-hidden="true"></i><span id="upsAllMetricsModalTitleText">UPS metrics</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3 small" id="upsAllMetricsModalSubtitle"></div>
                    <div id="upsAllMetricsGlobalError" class="alert alert-danger py-2 d-none" role="alert"></div>

                    <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
                        <label class="form-label mb-0" for="upsMetricsMetricSelect" id="upsMetricsMetricSelectLabel">Metric</label>
                        <select class="form-select form-select-sm" id="upsMetricsMetricSelect" aria-label="Metric select"></select>
                    </div>

                    <div id="upsMetricsChartEmpty" class="alert alert-light border small py-2 mb-3 d-none" role="status"></div>
                    <div id="upsMetricsChartWrap" class="position-relative" style="height: 200px;"><canvas id="upsMetricsChartCanvas" aria-label="UPS metric history chart"></canvas></div>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <!-- Top navigation -->
        <nav class="navbar app-topbar navbar-expand-lg mb-4">
            <div class="container-fluid app-topbar-inner">
                <a class="navbar-brand app-topbar-brand mb-0" href="#" role="button" onclick="event.preventDefault(); goToAppHome();">
                    <span class="app-topbar-brand-icon"><i class="bi bi-diagram-3"></i></span>
                    <span id="appName">HomeLab Monitor</span>
                </a>
                <button class="navbar-toggler app-topbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse app-topbar-collapse justify-content-lg-end" id="navbarNav">
                    <div class="app-topbar-toolbar">
                        <div class="app-topbar-actions">
                            <button type="button" class="btn btn-sm btn-outline-secondary app-topbar-btn" onclick="toggleSettings()" id="settingsBtn">
                                <i class="bi bi-sliders"></i><span id="settingsText">Settings</span>
                            </button>
                            <div class="dropdown">
                                <a class="btn btn-sm btn-outline-secondary app-topbar-btn dropdown-toggle d-inline-flex align-items-center homelab-menu-btn" href="#" id="serverMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true">
                                    <i class="bi bi-server flex-shrink-0" aria-hidden="true"></i>
                                    <span id="serverMenuTitle" class="homelab-menu-btn__current ms-1 text-truncate">Cluster</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="serverMenuDropdown">
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="cluster" onclick="goToAppHome()">
                                            <i class="bi bi-house-door me-2"></i><span id="menuHomelabHomeText">HomeLab</span>
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="services" onclick="openServicesMonitorFromMenu()">
                                            <i class="bi bi-activity me-2"></i><span id="menuServicesMonitorText">Service monitoring</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="vms" onclick="openVmsMonitorFromMenu()">
                                            <i class="bi bi-hdd-network me-2"></i><span id="menuVmsMonitorText">VM / CT status</span>
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="truenasPools" onclick="openTrueNASCategoryMonitorFromMenu('pools')">
                                            <i class="bi bi-hdd-stack me-2"></i><span id="menuTruenasPoolsMonitorText">TrueNAS — Pools</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="truenasDisks" onclick="openTrueNASCategoryMonitorFromMenu('disks')">
                                            <i class="bi bi-device-hdd me-2"></i><span id="menuTruenasDisksMonitorText">TrueNAS — Disks</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="truenasServices" onclick="openTrueNASCategoryMonitorFromMenu('services')">
                                            <i class="bi bi-gear me-2"></i><span id="menuTruenasServicesMonitorText">TrueNAS — Services</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="truenasApps" onclick="openTrueNASCategoryMonitorFromMenu('apps')">
                                            <i class="bi bi-box-seam me-2"></i><span id="menuTruenasAppsMonitorText">TrueNAS — Apps</span>
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="netdev" onclick="openNetdevMonitorFromMenu()">
                                            <i class="bi bi-diagram-3 me-2"></i><span id="menuNetdevMonitorText">Network devices (SNMP)</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="speedtest" onclick="openSpeedtestMonitorFromMenu()">
                                            <i class="bi bi-wifi me-2"></i><span id="menuSpeedtestMonitorText">Speedtest</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="iperf3" onclick="openIperf3MonitorFromMenu()">
                                            <i class="bi bi-arrow-left-right me-2"></i><span id="menuIperf3MonitorText">iperf3</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="ups" onclick="openUpsMonitorFromMenu()">
                                            <i class="bi bi-lightning-charge me-2"></i><span id="menuUpsMonitorText">UPS</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" type="button" data-homelab-view="smartSensors" onclick="openSmartSensorsMonitorFromMenu()">
                                            <i class="bi bi-house-heart me-2"></i><span id="menuSmartSensorsMonitorText">Smart sensors</span>
                                        </button>
                                    </li>
                                </ul>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary app-topbar-btn" onclick="toggleMonitorMode()" id="monitorModeBtn" title="Monitor mode">
                                <i class="bi bi-display"></i><span id="monitorModeText">Monitor</span>
                            </button>
                        </div>
                        <div class="app-topbar-status" role="group" aria-label="Status">
                            <span class="app-topbar-pill app-topbar-pill--server app-topbar-pill--ok" id="serverStatus">
                                <i class="bi bi-check-circle"></i><span id="serverStatusText">Server OK</span>
                            </span>
                            <span class="app-topbar-pill app-topbar-pill--conn" id="connectionStatus">
                                <i class="bi bi-wifi-off"></i><span id="notConnectedText">Not connected</span>
                            </span>
                            <span class="app-topbar-pill app-topbar-pill--host" id="currentServerBadge" style="display: none;">
                                <i class="bi bi-server"></i><span id="currentServerName"></span>
                            </span>
                        </div>
                        <button type="button" class="btn btn-sm btn-warning app-topbar-update-available" id="topbarUpdateAvailableBtn" style="display: none;" onclick="openLatestAppRelease()" aria-hidden="true">
                            <i class="bi bi-download" aria-hidden="true"></i><span class="js-topbar-update-label">Update</span>
                        </button>
                        <button type="button" class="btn btn-sm btn-primary app-topbar-refresh" onclick="refreshData()" id="refreshBtn">
                            <i class="bi bi-arrow-repeat"></i><span id="refreshText">Refresh</span>
                        </button>
                    </div>
                </div>
            </div>
        </nav>

        
