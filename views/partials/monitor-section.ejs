<!-- Панель режима монитора (тип сервера + навигация экранов + темы + выход) -->
        <div id="monitorToolbar" class="monitor-toolbar">
            <div class="monitor-toolbar-left">
                <span class="monitor-toolbar-title monitor-toolbar-title--home" id="monitorToolbarTitle" role="button" tabindex="0" onclick="goToAppHome()" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();goToAppHome();}">Монитор</span>
            </div>
            <div class="monitor-toolbar-theme">
                <span class="monitor-toolbar-update" id="monitorToolbarUpdate"></span>
                <div class="monitor-toolbar-nav-group" role="group" aria-label="Screens">
                    <button type="button" class="btn btn-sm monitor-toolbar-nav-btn" id="monitorPrevBtn" onclick="goMonitorView('prev')" title="←">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <button type="button" class="btn btn-sm monitor-toolbar-nav-btn" id="monitorHomeBtn" onclick="applyMonitorView('cluster')" title="">
                        <i class="bi bi-house-door"></i>
                    </button>
                    <button type="button" class="btn btn-sm monitor-toolbar-nav-btn" id="monitorNextBtn" onclick="goMonitorView('next')" title="→">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
                <button type="button" class="btn btn-sm monitor-toolbar-theme-btn" id="monitorRefreshBtn" onclick="refreshData()" title="">
                    <i class="bi bi-arrow-repeat"></i>
                </button>
                <button type="button" class="btn btn-sm monitor-toolbar-theme-btn active" id="monitorThemeLight" onclick="setMonitorTheme('light')" title="">
                    <i class="bi bi-sun-fill"></i>
                </button>
                <button type="button" class="btn btn-sm monitor-toolbar-theme-btn" id="monitorThemeDark" onclick="setMonitorTheme('dark')" title="">
                    <i class="bi bi-moon-stars-fill"></i>
                </button>
            </div>
            <div class="monitor-toolbar-right">
                <button type="button" class="btn btn-sm monitor-toolbar-hide-btn" id="monitorToolbarHideBtn" onclick="toggleMonitorToolbarHidden()" title="">
                    <i class="bi bi-chevron-up"></i>
                </button>
                <button type="button" class="btn btn-sm monitor-toolbar-settings" id="monitorSettingsBtn" onclick="openSettingsFromMonitor()" title="">
                    <i class="bi bi-gear me-1"></i><span id="monitorSettingsBtnText">Настройки</span>
                </button>
                <button type="button" class="btn btn-sm monitor-toolbar-exit" id="monitorExitBtnFixed" onclick="toggleMonitorMode()" title="">
                    <i class="bi bi-fullscreen-exit me-1"></i><span id="monitorExitBtnText">Выход</span>
                </button>
            </div>
        </div>
        <div id="monitorDotsDock" class="monitor-dots-dock">
            <div class="monitor-toolbar-dots" id="monitorScreenDots" aria-label="Monitor screens"></div>
        </div>
        <button type="button" id="monitorToolbarReveal" class="monitor-toolbar-reveal" onclick="toggleMonitorToolbarHidden()" style="display: none;" aria-hidden="true">
            <i class="bi bi-chevron-down"></i>
        </button>
    </div>

    
